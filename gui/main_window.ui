  <property name="styleSheet">
   <string notr="true">
QMainWindow {
    background-color: #0d1117;
}
QWidget#centralwidget {
    background-color: #0d1117;
}
QLabel#lblTitulo {
    color: #58a6ff;
    font-size: 22px;
    font-weight: bold;
    font-family: "Segoe UI";
    padding: 8px 0px;
}
QLabel#lblSubtitulo {
    color: #8b949e;
    font-size: 12px;
    font-family: "Segoe UI";
}
QLabel#lblProyectos {
    color: #c9d1d9;
    font-size: 13px;
    font-weight: bold;
    font-family: "Segoe UI";
    padding: 4px 0px;
}
QPushButton#btnRegresion {
    background-color: #161b22;
    color: #c9d1d9;
    border: 1px solid #30363d;
    border-radius: 10px;
    font-size: 14px;
    font-family: "Segoe UI";
    font-weight: bold;
    text-align: left;
    padding: 20px 24px;
}
QPushButton#btnRegresion:hover {
    background-color: #1f2937;
    border: 1px solid #58a6ff;
    color: #58a6ff;
}
QPushButton#btnRegresion:pressed {
    background-color: #0d1117;
    border: 1px solid #1f6feb;
}
QPushButton#btnIntegracion {
    background-color: #161b22;
    color: #c9d1d9;
    border: 1px solid #30363d;
    border-radius: 10px;
    font-size: 14px;
    font-family: "Segoe UI";
    font-weight: bold;
    text-align: left;
    padding: 20px 24px;
}
QPushButton#btnIntegracion:hover {
    background-color: #1f2937;
    border: 1px solid #3fb950;
    color: #3fb950;
}
QPushButton#btnIntegracion:pressed {
    background-color: #0d1117;
    border: 1px solid #238636;
}
QFrame#lineaSeparador {
    color: #21262d;
}
QStatusBar {
    background-color: #161b22;
    color: #8b949e;
    font-family: "Segoe UI";
    font-size: 11px;
    border-top: 1px solid #21262d;
}
QMenuBar {
    background-color: #161b22;
    color: #c9d1d9;
    font-family: "Segoe UI";
    font-size: 12px;
    border-bottom: 1px solid #21262d;
}
QMenuBar::item:selected {
    background-color: #21262d;
    color: #58a6ff;
}
QMenu {
    background-color: #161b22;
    color: #c9d1d9;
    border: 1px solid #30363d;
    font-family: "Segoe UI";
}
QMenu::item:selected {
    background-color: #21262d;
    color: #58a6ff;
}
   </string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="verticalLayout">
